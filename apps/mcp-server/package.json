{
  "name": "@studio/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "studio-mcp": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "bun --watch src/index.ts --transport=auto",
    "dev:http": "bun --watch src/index.ts --transport=http",
    "dev:stdio": "bun --watch src/index.ts --transport=stdio",
    "start": "bun src/index.ts --transport=auto",
    "start:http": "bun src/index.ts --transport=http",
    "start:stdio": "bun src/index.ts --transport=stdio",
    "smoke:http": "bun scripts/smoke-http.ts",
    "test": "vitest run src/__tests__/runtime.test.ts src/__tests__/tools.test.ts src/__tests__/transport.test.ts src/__tests__/studio-api-client.test.ts",
    "test:e2e": "vitest run src/__tests__/process-e2e.test.ts --pool=forks",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@paper-design/shaders-react": "^0.0.71",
    "@studio/shared-types": "*",
    "@studio/template-registry": "*",
    "@studio/renderer": "*",
    "@studio/ai-generation": "*",
    "@remotion/player": "4.0.445",
    "@remotion/transitions": "4.0.445",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "esbuild": "^0.25.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "4.0.445",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
