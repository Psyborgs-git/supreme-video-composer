{
  "name": "remotion-studio",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '@studio/app' dev",
    "dev:all": "bun run build:types && bun run --filter '@studio/shared-types' dev & bun run --filter '@studio/renderer' dev & bun run --filter '@studio/app' dev & wait",
    "dev:mcp": "bun run --filter '@studio/mcp-server' dev",
    "build": "bun run --filter '@studio/shared-types' build && bun run --filter '@studio/renderer' build && bun run --filter '@studio/mcp-server' build && bun run --filter '@studio/app' build",
    "build:types": "bun run --filter '@studio/shared-types' build",
    "build:renderer": "bun run --filter '@studio/renderer' build",
    "build:mcp": "bun run --filter '@studio/mcp-server' build",
    "build:app": "bun run --filter '@studio/app' build",
    "test": "bun run --filter '*' test",
    "test:types": "bun run --filter '@studio/shared-types' test",
    "test:registry": "bun run --filter '@studio/template-registry' test",
    "test:renderer": "bun run --filter '@studio/renderer' test",
    "test:mcp": "bun run --filter '@studio/mcp-server' test",
    "studio": "bun run --filter '@studio/remotion-compositions' studio",
    "type-check": "bun run --filter '*' type-check"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "zod": "4.3.6"
  }
}
