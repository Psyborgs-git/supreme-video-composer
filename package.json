{
  "name": "remotion-studio",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run --workspace @studio/app dev",
    "dev:all": "npm run build:types && npm run --workspace @studio/shared-types dev & npm run --workspace @studio/renderer dev & npm run --workspace @studio/app dev & wait",
    "dev:mcp": "npm run --workspace @studio/mcp-server dev",
    "mcp:http": "npm run --workspace @studio/mcp-server start:http",
    "mcp:stdio": "npm run --workspace @studio/mcp-server start:stdio",
    "smoke:mcp:http": "npm run --workspace @studio/mcp-server smoke:http",
    "build": "npm run --workspace @studio/shared-types build && npm run --workspace @studio/database build && npm run --workspace @studio/auth build && npm run --workspace @studio/billing build && npm run --workspace @studio/renderer build && npm run --workspace @studio/mcp-server build && npm run --workspace @studio/app build",
    "build:types": "npm run --workspace @studio/shared-types build",
    "build:renderer": "npm run --workspace @studio/renderer build",
    "build:mcp": "npm run --workspace @studio/mcp-server build",
    "build:app": "npm run --workspace @studio/app build",
    "test": "npm run test --workspaces --if-present",
    "test:types": "npm run --workspace @studio/shared-types test",
    "test:registry": "npm run --workspace @studio/template-registry test",
    "test:renderer": "npm run --workspace @studio/renderer test",
    "test:ai": "npm run --workspace @studio/ai-generation test",
    "test:mcp": "npm run --workspace @studio/mcp-server test",
    "test:mcp:e2e": "npm run --workspace @studio/mcp-server test:e2e",
    "studio": "npm run --workspace @studio/remotion-compositions studio",
    "type-check": "npm run type-check --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "overrides": {
    "remotion": "4.0.445",
    "@remotion/bundler": "4.0.445",
    "@remotion/cli": "4.0.445",
    "@remotion/google-fonts": "4.0.445",
    "@remotion/media-utils": "4.0.445",
    "@remotion/noise": "4.0.445",
    "@remotion/paths": "4.0.445",
    "@remotion/player": "4.0.445",
    "@remotion/renderer": "4.0.445",
    "@remotion/shapes": "4.0.445",
    "@remotion/transitions": "4.0.445"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "zod": "^3.23.0"
  }
}
