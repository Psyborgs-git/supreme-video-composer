{
  "name": "remotion-studio",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run --workspace @studio/app dev",
    "dev:all": "npm run build:types && npm run --workspace @studio/shared-types dev & npm run --workspace @studio/renderer dev & npm run --workspace @studio/app dev & wait",
    "dev:mcp": "npm run --workspace @studio/mcp-server dev",
    "build": "npm run --workspace @studio/shared-types build && npm run --workspace @studio/renderer build && npm run --workspace @studio/mcp-server build && npm run --workspace @studio/app build",
    "build:types": "npm run --workspace @studio/shared-types build",
    "build:renderer": "npm run --workspace @studio/renderer build",
    "build:mcp": "npm run --workspace @studio/mcp-server build",
    "build:app": "npm run --workspace @studio/app build",
    "test": "npm run test --workspaces --if-present",
    "test:types": "npm run --workspace @studio/shared-types test",
    "test:registry": "npm run --workspace @studio/template-registry test",
    "test:renderer": "npm run --workspace @studio/renderer test",
    "test:mcp": "npm run --workspace @studio/mcp-server test",
    "studio": "npm run --workspace @studio/remotion-compositions studio",
    "type-check": "npm run type-check --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "zod": "^3.23.0"
  }
}
