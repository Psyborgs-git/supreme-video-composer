ASSETS_DIR=./data/assets
PROJECTS_DIR=./data/projects
EXPORTS_DIR=./data/exports
HOST=0.0.0.0

# Database configuration
# Remotion Studio currently uses SQLite via better-sqlite3.
# Local host runs use a workspace file; Docker uses DOCKER_DATABASE_URL below.
DATABASE_URL=file:./data/projects/studio.db
DOCKER_DATABASE_URL=file:/data/projects/studio.db

# Session & Auth
SESSION_SECRET=change-me-to-a-32-byte-random-secret-32-chars-
APP_URL=http://localhost:3000

# Docker port configuration
HOST_STUDIO_PORT=3000
HOST_MCP_PORT=9090
