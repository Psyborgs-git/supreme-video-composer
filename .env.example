# ─── Database ────────────────────────────────────────────────────────────────
# Remotion Studio currently uses SQLite (better-sqlite3 + drizzle sqlite-core).
# A Postgres URL is NOT supported by the current database package.
DATABASE_URL=file:./data/projects/studio.db

# Docker containers need an in-container path backed by the compose bind mount.
DOCKER_DATABASE_URL=file:/data/projects/studio.db

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-32-byte-random-secret

# Public app URL (used for OAuth redirect URIs)
APP_URL=http://localhost:3000

# GitHub OAuth — create at https://github.com/settings/applications/new
# Callback URL: http://localhost:3000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Billing (Stripe) ─────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs from your Stripe dashboard
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_TEAM=

# ─── MCP Server ───────────────────────────────────────────────────────────────
# Long-lived token for machine-to-machine (m2m) Studio API access
STUDIO_API_TOKEN=

# ─── AI Text / Script providers ───────────────────────────────────────────────
# Set AI_TEXT_PROVIDER to one of: openai | google-vertex | gemini | mock (default)
AI_TEXT_PROVIDER=mock
AI_TEXT_MODEL=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Vertex AI — https://cloud.google.com/vertex-ai
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_VERTEX_API_KEY=

# Gemini API (Google AI Studio) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── AI Image providers ───────────────────────────────────────────────────────
# Set AI_IMAGE_PROVIDER to one of: openai | google-vertex | aws | mock (default)
AI_IMAGE_PROVIDER=mock
AI_IMAGE_MODEL=

# AWS Bedrock (Titan Image + Nova Reel) — https://aws.amazon.com/bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Required only for Nova Reel video output storage
AWS_S3_OUTPUT_BUCKET=

# ─── AI Audio providers ───────────────────────────────────────────────────────
# Set AI_AUDIO_PROVIDER to one of: openai | elevenlabs | mock (default)
AI_AUDIO_PROVIDER=mock
AI_AUDIO_MODEL=

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ─── AI Video providers ───────────────────────────────────────────────────────
# Set AI_VIDEO_PROVIDER to one of: higgsfield | runway | luma | synthesia | aws | mock (default)
AI_VIDEO_PROVIDER=mock

# Higgsfield AI — https://app.higgsfield.ai/account/api-keys
HIGGSFIELD_API_KEY=

# Runway ML — https://app.runwayml.com/account/api-keys
RUNWAY_API_SECRET=

# Luma AI (Dream Machine) — https://lumalabs.ai/dream-machine/api/keys
LUMA_API_KEY=

# Synthesia — https://app.synthesia.io/#/account/api-access
SYNTHESIA_API_KEY=

# ─── Docker Compose overrides ─────────────────────────────────────────────────
# POSTGRES_PASSWORD=studio_dev
# HOST_STUDIO_PORT=3000
# HOST_MCP_PORT=9090
# HOST_POSTGRES_PORT=5432

